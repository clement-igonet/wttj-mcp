# Credentials — copy to .env and fill in your values.
# The session key is auto-refreshed by scripts/refresh_token.py every time
# Claude starts the MCP. You don't need to set it manually.

WTTJ_EMAIL=your-email@example.com
WTTJ_PASSWORD=your-password

# Auto-managed — do not edit manually (overwritten by refresh_token.py)
WTTJ_SESSION_KEY=
