# Copy this file to .env
#
# Preferred: JWT token (bypasses reCAPTCHA)
# How to get it:
#   1. Log in at welcometothejungle.com in your browser
#   2. DevTools → Network → find GET api.welcometothejungle.com/api/v2/users/me
#   3. Preview tab → copy the value of the "token" field
WTTJ_TOKEN=your-jwt-token-here

# Fallback: email/password (blocked by reCAPTCHA in most envs)
WTTJ_EMAIL=your-email@example.com
WTTJ_PASSWORD=your-password
